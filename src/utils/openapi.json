{
  "openapi": "3.1.0",
  "info": {
    "title": "ConnectX API",
    "version": "1.0.0",
    "description": "API documentation for ConnectX, a developer connection platform."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Local development server"
    }
  ],
  "tags": [
    {
      "name": "Health",
      "description": "Server health endpoints"
    },
    {
      "name": "Auth",
      "description": "Authentication and password management"
    },
    {
      "name": "Profile",
      "description": "Logged-in user profile endpoints"
    },
    {
      "name": "Connections",
      "description": "Connection request actions"
    },
    {
      "name": "User",
      "description": "User feed, requests, and connections"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "tags": ["Health"],
        "summary": "Check server health",
        "description": "Returns a simple message when the server is running.",
        "operationId": "healthCheck",
        "responses": {
          "200": {
            "description": "Server is running",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Server is up and running"
                    }
                  },
                  "required": ["message"]
                }
              }
            }
          }
        }
      }
    },
    "/auth/sign-up": {
      "post": {
        "tags": ["Auth"],
        "summary": "Create a new user account",
        "operationId": "signUp",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignUpRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Account created successfully",
            "headers": {
              "Set-Cookie": {
                "description": "Sets accessToken and refershToken cookies.",
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/User"
                        },
                        "message": {
                          "example": "Sing-up successfull"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/auth/sing-up": {
      "post": {
        "tags": ["Auth"],
        "summary": "Sign in a user",
        "description": "Authenticates a user. This route is currently mounted as /auth/sing-up in the application.",
        "operationId": "signIn",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignInRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Signed in successfully",
            "headers": {
              "Set-Cookie": {
                "description": "Sets accessToken and refershToken cookies.",
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/User"
                        },
                        "message": {
                          "example": "Sign-in Succefull"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/auth/sign-out": {
      "post": {
        "tags": ["Auth"],
        "summary": "Sign out the logged-in user",
        "operationId": "signOut",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Signed out successfully",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object"
                        },
                        "message": {
                          "example": "Sign-out Successfull"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/auth/change-password": {
      "post": {
        "tags": ["Auth"],
        "summary": "Change logged-in user's password",
        "operationId": "changePassword",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChangePasswordRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password changed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/User"
                          }
                        },
                        "message": {
                          "example": "Password chnaged succesfully"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/auth/forgot-password": {
      "post": {
        "tags": ["Auth"],
        "summary": "Send password reset email",
        "operationId": "forgotPassword",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ForgotPasswordRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password reset email sent",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "additionalProperties": true
                        },
                        "message": {
                          "example": "Mail sent successfully"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/auth/reset-password/{token}": {
      "post": {
        "tags": ["Auth"],
        "summary": "Reset password using token",
        "operationId": "resetPassword",
        "parameters": [
          {
            "$ref": "#/components/parameters/ResetToken"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResetPasswordRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password reset successfully",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object"
                        },
                        "message": {
                          "example": "Password updated successfully. You can now log in."
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/profile/view": {
      "post": {
        "tags": ["Profile"],
        "summary": "Get logged-in user's profile",
        "operationId": "profileView",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Profile fetched successfully",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/User"
                        },
                        "message": {
                          "example": "Profile fetched succesfully"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/profile/edit": {
      "patch": {
        "tags": ["Profile"],
        "summary": "Edit logged-in user's profile",
        "description": "Updates editable profile fields. The route is currently wired to the profile view controller in code.",
        "operationId": "profileEdit",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProfileEditRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Profile updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/User"
                        },
                        "message": {
                          "example": "Profile updated succesfully"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/request/request/send/{status}/{toUserId}": {
      "post": {
        "tags": ["Connections"],
        "summary": "Send a connection request",
        "operationId": "sendRequest",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ConnectionSendStatus"
          },
          {
            "$ref": "#/components/parameters/ToUserId"
          }
        ],
        "responses": {
          "200": {
            "description": "Connection request sent successfully",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object"
                        },
                        "message": {
                          "example": "Connection request sent succesfully"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/request/request/review/{status}/{requestId}": {
      "post": {
        "tags": ["Connections"],
        "summary": "Review a connection request",
        "operationId": "reviewRequest",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ConnectionReviewStatus"
          },
          {
            "$ref": "#/components/parameters/RequestId"
          }
        ],
        "responses": {
          "200": {
            "description": "Request reviewed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object"
                        },
                        "message": {
                          "example": "Request fetched"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/user/requests/recived": {
      "post": {
        "tags": ["User"],
        "summary": "Get received connection requests",
        "operationId": "getAllRequest",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Received requests fetched successfully",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object"
                        },
                        "message": {
                          "example": "All request fetched successfully"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/user/connections": {
      "post": {
        "tags": ["User"],
        "summary": "Get all user connections",
        "operationId": "getAllConnection",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Connections fetched successfully",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object"
                        },
                        "message": {
                          "example": "All connections fetched successfully"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/user/feed": {
      "post": {
        "tags": ["User"],
        "summary": "Get user feed",
        "operationId": "getFeed",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Feed fetched successfully",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object"
                        },
                        "message": {
                          "example": "Feed fetched succesfully"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Use the access token returned from sign in/sign up."
      },
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "accessToken",
        "description": "JWT access token stored in the accessToken cookie."
      }
    },
    "parameters": {
      "ResetToken": {
        "name": "token",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Password reset token received by email."
      },
      "ConnectionSendStatus": {
        "name": "status",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "enum": ["pass", "like"]
        },
        "description": "Connection request action."
      },
      "ConnectionReviewStatus": {
        "name": "status",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "enum": ["accept", "reject"]
        },
        "description": "Review action for a connection request."
      },
      "ToUserId": {
        "name": "toUserId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{24}$",
          "example": "65f0c6fbd0f4e7a7b4b0a111"
        },
        "description": "MongoDB ObjectId of the target user."
      },
      "RequestId": {
        "name": "requestId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{24}$",
          "example": "65f0c6fbd0f4e7a7b4b0a222"
        },
        "description": "MongoDB ObjectId of the connection request."
      }
    },
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "integer",
            "example": 200
          },
          "data": {
            "description": "Response payload."
          },
          "message": {
            "type": "string",
            "example": "Success"
          }
        },
        "required": ["statusCode", "data", "message"]
      },
      "ErrorResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ApiResponse"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "type": "object"
              },
              "message": {
                "type": "string",
                "example": "Unauthorized"
              }
            }
          }
        ]
      },
      "User": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{24}$",
            "example": "65f0c6fbd0f4e7a7b4b0a333"
          },
          "firstname": {
            "type": "string",
            "example": "Kunal"
          },
          "lastname": {
            "type": "string",
            "example": "Kumar"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "kunal@example.com"
          },
          "avatar": {
            "type": "string",
            "format": "uri",
            "example": "https://example.com/avatar.png"
          },
          "age": {
            "type": "integer",
            "minimum": 18,
            "maximum": 108,
            "example": 24
          },
          "gender": {
            "type": "string",
            "enum": ["male", "female", "others"],
            "example": "male"
          },
          "skills": {
            "type": "array",
            "maxItems": 15,
            "items": {
              "type": "string"
            },
            "example": ["TypeScript", "Node.js", "MongoDB"]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "SignUpRequest": {
        "type": "object",
        "properties": {
          "firstname": {
            "type": "string",
            "example": "Kunal"
          },
          "lastname": {
            "type": "string",
            "example": "Kumar"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "kunal@example.com"
          },
          "password": {
            "type": "string",
            "format": "password",
            "minLength": 8,
            "example": "StrongPass@123"
          }
        },
        "required": ["firstname", "lastname", "email", "password"]
      },
      "SignInRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "kunal@example.com"
          },
          "password": {
            "type": "string",
            "format": "password",
            "example": "StrongPass@123"
          }
        },
        "required": ["email", "password"]
      },
      "ChangePasswordRequest": {
        "type": "object",
        "properties": {
          "oldPassword": {
            "type": "string",
            "format": "password",
            "example": "OldStrongPass@123"
          },
          "newPassword": {
            "type": "string",
            "format": "password",
            "minLength": 8,
            "example": "NewStrongPass@123"
          }
        },
        "required": ["oldPassword", "newPassword"]
      },
      "ForgotPasswordRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "kunal@example.com"
          }
        },
        "required": ["email"]
      },
      "ResetPasswordRequest": {
        "type": "object",
        "properties": {
          "password": {
            "type": "string",
            "format": "password",
            "minLength": 8,
            "example": "NewStrongPass@123"
          }
        },
        "required": ["password"]
      },
      "ProfileEditRequest": {
        "type": "object",
        "properties": {
          "firstname": {
            "type": "string",
            "example": "Kunal"
          },
          "lastname": {
            "type": "string",
            "example": "Kumar"
          },
          "avatar": {
            "type": "string",
            "format": "uri",
            "example": "https://example.com/avatar.png"
          },
          "age": {
            "type": "integer",
            "minimum": 18,
            "maximum": 108,
            "example": 24
          },
          "gender": {
            "type": "string",
            "enum": ["male", "female", "others"],
            "example": "male"
          },
          "skills": {
            "type": "array",
            "maxItems": 15,
            "items": {
              "type": "string"
            },
            "example": ["TypeScript", "Express", "React"]
          }
        },
        "additionalProperties": false
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "statusCode": 400,
              "data": {},
              "message": "Invalid request"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "statusCode": 401,
              "data": {},
              "message": "Unauthorized"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "statusCode": 404,
              "data": {},
              "message": "User not found"
            }
          }
        }
      }
    }
  }
}
